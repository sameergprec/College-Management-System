<div class="container mt-5" style="font-size: 13px;">
  <div class="text-center mb-5">
    <h2 class="fw-bold text-dark" style="font-size: 24px;">👑 Welcome to Admin Panel</h2>
    <p class="text-muted" style="font-size: 12px;">Manage users, departments, and academic data with ease.</p>
  </div>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% cards = [
      { title: "👨‍🎓 Manage Students", desc: "View, add, and edit student records.", path: admin_students_path, bg: "linear-gradient(to right, #fceabb, #f8b500)" },
      { title: "👨‍🏫 Manage Teachers", desc: "Update teacher data and their assignments.", path: admin_teachers_path, bg: "linear-gradient(to right, #d4fc79, #96e6a1)" },
      { title: "🏢 Manage Departments", desc: "Add and update academic departments.", path: admin_departments_path, bg: "linear-gradient(to right, #a1c4fd, #c2e9fb)" },
      { title: "📊 Academic Records", desc: "Track semester-wise academic performance.", path: admin_academic_details_path, bg: "linear-gradient(to right, #fbc2eb, #a6c1ee)" },
      { title: "🔐 Manage Users", desc: "Control platform users and their roles.", path: admin_users_path, bg: "linear-gradient(to right, #fddb92, #d1fdff)" }
    ] %>

    <% cards.each do |card| %>
      <div class="col">
        <div class="card h-100 border-0 shadow-lg rounded-4 text-dark" style="background: <%= card[:bg] %>; transition: transform 0.2s;">
          <div class="card-body">
            <h6 class="fw-bold mb-2"><%= card[:title] %></h6>
            <p class="mb-3" style="font-size: 12px;"><%= card[:desc] %></p>
            <%= link_to "Go ➡", card[:path], class: "btn btn-sm btn-light rounded-pill px-3 shadow-sm fw-semibold" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
