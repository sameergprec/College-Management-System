<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

    <div>
      <h2 class="fw-bold text-primary mb-1">
        📚 <%= @subject.persisted? ? "Update Subject" : "Add Subject" %>
      </h2>

      <p class="text-muted mb-0">
        Semester <%= @department_semester.semester_no %>
      </p>
    </div>

    <%= link_to "⬅ Back",
        admin_department_department_semester_subjects_path(
          @department,
          @department_semester
        ),
        class: "btn btn-outline-secondary rounded-pill px-4 shadow-sm" %>

  </div>

  <div class="card border-0 shadow-lg rounded-4">

    <div class="card-body p-4">

      <%= form_with model: [
        :admin,
        @department,
        @department_semester,
        @subject
      ] do |f| %>

        <div class="row">

          <div class="col-md-6 mb-4">

            <%= f.label :subject_code,
                class: "form-label fw-semibold text-dark" %>

            <%= f.text_field :subject_code,
                class: "form-control rounded-3 shadow-sm py-2" %>

          </div>

          <div class="col-md-6 mb-4">

            <%= f.label :subject_name,
                class: "form-label fw-semibold text-dark" %>

            <%= f.text_field :subject_name,
                class: "form-control rounded-3 shadow-sm py-2" %>

          </div>

          <div class="col-md-6 mb-4">

            <%= f.label :credits,
                class: "form-label fw-semibold text-dark" %>

            <%= f.number_field :credits,
                class: "form-control rounded-3 shadow-sm py-2" %>

          </div>

          <div class="col-md-6 mb-4">

            <%= f.label :subject_type,
                class: "form-label fw-semibold text-dark" %>

            <%= f.select :subject_type,
                ["Theory", "Lab"],
                {},
                class: "form-select rounded-3 shadow-sm py-2" %>

          </div>

        </div>

        <div class="d-flex gap-3 mt-3">

          <%= f.submit @subject.persisted? ? "Update Subject" : "Create Subject",
              class: "btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-semibold" %>

          <%= link_to "Cancel",
              admin_department_department_semester_subjects_path(
                @department,
                @department_semester
              ),
              class: "btn btn-light border rounded-pill px-4 py-2 shadow-sm" %>

        </div>

      <% end %>

    </div>

  </div>

</div>