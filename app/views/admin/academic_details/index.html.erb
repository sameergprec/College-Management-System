<div class="container mt-5">

  <div class="text-center mb-5">

    <h2 class="fw-bold">
      📊 Academic Records
    </h2>

    <p class="text-muted">
      Select a department to manage academics
    </p>

  </div>

  <div class="row">

    <% Department.all.each do |department| %>

      <div class="col-md-4 mb-4">

        <div class="card border-0 shadow-lg rounded-4 h-100">

          <div class="card-body text-center">

            <h4 class="fw-bold mb-3">
              <%= department.name %>
            </h4>

            <p class="text-muted">
              Manage semesters, subjects,
              and student marks
            </p>

            <%= link_to "Open Department",admin_department_department_semesters_path(department), class: "btn btn-dark rounded-pill px-4" %>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>