<div class="container mt-5" style="font-size: 12x"> <!-- Reduced font size -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-semibold text-dark mb-0">👤 User Management Panel</h5>
    <div>
      <%= link_to "➕ New User", new_admin_user_path, class: "btn btn-success shadow-sm rounded-pill px-3 py-1" %>
      <%= link_to "⬅ Back", admins_dashboard_path, class: "btn btn-outline-secondary shadow-sm rounded-pill px-3 py-1 ms-2" %>
    </div>
  </div>

  <!-- Role Filter Buttons -->
  <div class="mb-3 d-flex flex-wrap gap-2">
    <%= link_to "All", admin_users_path, class: "btn btn-outline-primary btn-sm rounded-pill px-3 py-1 #{params[:role].blank? ? 'active' : ''}" %>
    <% User.distinct.pluck(:role).each do |role| %>
      <%= link_to role.titleize, admin_users_path(role: role), class: "btn btn-outline-primary btn-sm rounded-pill px-3 py-1 #{params[:role] == role ? 'active' : ''}" %>
    <% end %>
  </div>

  <!-- User Table -->
  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
      <table class="table table-hover mb-0 align-middle" style="font-size: 12px"> <!-- Smaller table font -->
        <thead class="table-light text-center">
          <tr>
            <th>📧 Email</th>
            <th>🎭 Role</th>
            <th>⚙️ Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="text-center"><%= user.email %></td>
              <td class="text-center">
                <% role_class = case user.role
                  when "admin" then "bg-warning text-dark"
                  when "student" then "bg-primary text-white"
                  when "teacher" then "bg-dark text-white"
                  when "department" then "bg-danger text-white"
                  else "bg-info text-white"
                end %>
                <span class="badge <%= role_class %> px-3 py-1 rounded-pill" style="font-size: 12px;">
                  <%= user.role.titleize %>
                </span>
              </td>
              <td class="text-center d-flex justify-content-center">
                <%= link_to "✏️", edit_admin_user_path(user), class: "btn btn-outline-warning btn-sm rounded-pill me-1 px-2 py-1" %>
                <%= button_to "🗑", admin_user_path(user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm rounded-pill px-2 py-1" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
