<div class="container my-5" style="background-color: #f4f6f9; padding: 30px; border-radius: 20px; font-size: 12px; box-shadow: 0 0 10px rgba(0,0,0,0.05);">

  <div class="text-center mb-4">
    <h2 class="fw-bold text-success" style="font-size: 16px;">➕ Add New Student</h2>
    <p class="text-muted" style="font-size: 12px;">Fill out the details to register a new student.</p>
  </div>

  <%= render 'form' %>

  <div class="text-center mt-3">
    <%= link_to "← Back to Students", admin_students_path, class: "btn btn-outline-secondary btn-sm fw-semibold rounded-pill px-3 py-1" %>
  </div>

</div>
