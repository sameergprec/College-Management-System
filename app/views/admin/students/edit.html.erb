<div class="container py-5">

  <!-- PAGE HEADER -->
  <div class="card border-0 shadow-lg rounded-5 overflow-hidden mb-4">

    <div class="p-5 text-white"
         style="background: linear-gradient(135deg, #0f172a, #1e40af, #2563eb);">

      <div class="d-flex justify-content-between align-items-center flex-wrap gap-4">

        <!-- LEFT -->
        <div>

          <h2 class="fw-bold mb-2">
            ✏️ Edit Student Details
          </h2>

          <p class="mb-0 text-light opacity-75">
            Update and manage student academic information
          </p>

        </div>

        <!-- RIGHT PROFILE -->
        <div class="text-center">

          <% if @student.profile_picture.attached? %>

            <%= image_tag @student.profile_picture.variant(resize_to_fill: [100,100]),
                class: "rounded-circle border border-4 border-white shadow-lg" %>

          <% else %>

            <div class="bg-white text-dark rounded-circle shadow-lg d-flex align-items-center justify-content-center"
                 style="width:100px;height:100px;font-size:38px;">

              👨‍🎓

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

  <!-- QUICK INFO -->
  <div class="row g-4 mb-4">

    <div class="col-md-3">

      <div class="card border-0 shadow-sm rounded-4 h-100">

        <div class="card-body">

          <small class="text-muted d-block mb-1">
            Roll Number
          </small>

          <h6 class="fw-bold text-primary mb-0">
            <%= @student.roll_no %>
          </h6>

        </div>

      </div>

    </div>

    <div class="col-md-3">

      <div class="card border-0 shadow-sm rounded-4 h-100">

        <div class="card-body">

          <small class="text-muted d-block mb-1">
            Department
          </small>

          <h6 class="fw-bold text-success mb-0">
            <%= @student.department&.code %>
          </h6>

        </div>

      </div>

    </div>

    <div class="col-md-3">

      <div class="card border-0 shadow-sm rounded-4 h-100">

        <div class="card-body">

          <small class="text-muted d-block mb-1">
            Semester
          </small>

          <h6 class="fw-bold text-warning mb-0">
            Semester <%= @student.semester %>
          </h6>

        </div>

      </div>

    </div>

    <div class="col-md-3">

      <div class="card border-0 shadow-sm rounded-4 h-100">

        <div class="card-body">

          <small class="text-muted d-block mb-1">
            Section
          </small>

          <h6 class="fw-bold text-danger mb-0">
            <%= @student.section %>
          </h6>

        </div>

      </div>

    </div>

  </div>

  <!-- FORM SECTION -->
  <div class="card border-0 shadow-lg rounded-5 overflow-hidden">

    <div class="card-header bg-white border-0 py-4">

      <h4 class="fw-bold text-dark mb-1">
        📝 Update Information
      </h4>

      <p class="text-muted mb-0">
        Modify the student details carefully before saving.
      </p>

    </div>

    <div class="card-body bg-light p-4">

      <%= render 'form' %>

    </div>

  </div>

  <!-- FOOTER BUTTONS -->
  <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">

    <%= link_to "👁 View Student",
        admin_student_path(@student),
        class: "btn btn-outline-primary rounded-pill px-4 py-2 fw-semibold shadow-sm" %>

    <%= link_to "👨‍🎓 All Students",
        admin_students_path,
        class: "btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold shadow-sm" %>

  </div>

</div>

<style>

  body {
    background: #f4f7fb;
  }

  .card {
    transition: 0.3s ease;
  }

  .card:hover {
    transform: translateY(-2px);
  }

  .btn {
    transition: 0.25s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

</style>