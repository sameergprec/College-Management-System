<!-- Scrolling Notice Bar -->
<div class="bg-dark text-light py-1 w-100 m-0">
  <marquee behavior="scroll" direction="left" scrollamount="5">
    Admissions Open for 2025-26 | POLYCET College Code: RORP | EAPCET/ECET College Code: RORE | PGECET College Code: RORG
  </marquee>
</div>

<!-- Footer -->
<footer class="bg-dark text-light pt-5 pb-4 w-100 m-0">
  <div class="container-fluid px-4">
    <div class="row">

      <!-- Quick Links -->
      <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Quick Links</h5>
        <p><%= link_to "Home", root_path, class: "text-light text-decoration-none" %></p>
        <p><%= link_to "Admissions", "#admissions", class: "text-light text-decoration-none" %></p>
        <p><%= link_to "Departments", "#departments", class: "text-light text-decoration-none" %></p>
        <p><%= link_to "Contact", "#contact", class: "text-light text-decoration-none" %></p>
      </div>

      <!-- Contact Us -->
      <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Contact Us</h5>
        <p><i class="fas fa-home me-2"></i> ROREC Campus, Hyderabad, Telangana</p>
        <p><i class="fas fa-envelope me-2"></i> info@rorec.edu.in</p>
        <p><i class="fas fa-phone me-2"></i> +91 9876543210</p>
      </div>

      <!-- Social Media -->
      <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
        <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Follow Us</h5>
        <p><a href="#" class="text-light text-decoration-none"><i class="fab fa-facebook-f me-2"></i>Facebook</a></p>
        <p><a href="#" class="text-light text-decoration-none"><i class="fab fa-instagram me-2"></i>Instagram</a></p>
        <p><a href="#" class="text-light text-decoration-none"><i class="fab fa-twitter me-2"></i>Twitter</a></p>
        <p><a href="#" class="text-light text-decoration-none"><i class="fab fa-youtube me-2"></i>YouTube</a></p>
      </div>

      <!-- College Logo & Codes -->
      <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3 text-center">
        <img src="/icon.png" alt="College Logo" style="width: 60px; height: 60px;" class="mb-2">
        <h6 class="text-warning mt-2">College Codes:</h6>
        <p class="mb-1">POLYCET: <strong>RORP</strong></p>
        <p class="mb-1">EAPCET/ECET: <strong>RORE</strong></p>
        <p class="mb-1">PGECET: <strong>RORG</strong></p>
      </div>

    </div>

    <!-- Footer Bottom -->
    <div class="row mt-4">
      <div class="col-md-12 text-center">
        <p class="text-muted mb-0">&copy; <%= Time.current.year %> ROREC - Ruby On Rails Engineering College. All Rights Reserved.</p>
      </div>
    </div>
  </div>
</footer>
