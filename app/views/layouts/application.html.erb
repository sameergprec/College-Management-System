<!DOCTYPE html>
<html>

<head>

  <title><%= content_for(:title) || "College Management System" %></title>

  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

  <%= javascript_importmap_tags %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css"
        rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <!-- Favicon -->
  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="apple-touch-icon" href="/icon.png">

</head>

<body class="d-flex flex-column min-vh-100">

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark shadow-sm"
       style="background: linear-gradient(to right, rgb(0, 2, 35), rgb(61, 27, 116), rgb(183, 52, 52));">

    <div class="container-fluid">

      <!-- Logo -->
      <%= link_to root_path,
          class: "navbar-brand d-flex flex-column text-decoration-none text-light" do %>

        <div class="d-flex align-items-center gap-2">

          <i class="bi bi-mortarboard-fill"
             style="font-size: 2rem; color: #ff4da6;"></i>

          <span style="color: #ff4da6;
                       font-size: 2rem;
                       font-weight: bold;
                       letter-spacing: 1px;">

            ROREC

          </span>

        </div>

        <small class="text-light" style="font-size: 0.6rem;">
          Ruby On Rails Engineering College : (Autonomous)
        </small>

      <% end %>

      <!-- Mobile Toggle -->
      <button class="navbar-toggler"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#navbarContent">

        <span class="navbar-toggler-icon"></span>

      </button>

      <!-- Navbar Content -->
      <div class="collapse navbar-collapse" id="navbarContent">

        <!-- NAV LINKS -->
        <ul class="navbar-nav mx-auto gap-lg-2">

          <li class="nav-item">
            <%= link_to "Home", root_path,
                class: "nav-link text-white" %>
          </li>

          <li class="nav-item">
            <%= link_to "Results", results_path,
                class: "nav-link text-white" %>  
          </li>

          <% if user_signed_in? %>

            <% if current_user.role == "admin" %>

              <li class="nav-item">
                <%= link_to "Dashboard",
                    admins_dashboard_path,
                    class: "nav-link text-white" %>
              </li>

              <li class="nav-item">
                <%= link_to "Departments",
                    admin_departments_path,
                    class: "nav-link text-white" %>
              </li>

              <li class="nav-item">
                <%= link_to "Students",
                    admin_students_path,
                    class: "nav-link text-white" %>
              </li>

              <li class="nav-item">
                <%= link_to "Teachers",
                    admin_teachers_path,
                    class: "nav-link text-white" %>
              </li>

            <% elsif current_user.role == "department" %>

              <li class="nav-item">
                <%= link_to "Dashboard",
                    departments_dashboard_path,
                    class: "nav-link text-white" %>
              </li>

              <li class="nav-item">
                <%= link_to "Students",
                    department_students_path,
                    class: "nav-link text-white" %>
              </li>

              <li class="nav-item">
                <%= link_to "Teachers",
                    department_teachers_path,
                    class: "nav-link text-white" %>
              </li>

            <% elsif current_user.role == "teacher" %>

              <li class="nav-item">
                <%= link_to "Dashboard",
                    teachers_dashboard_path,
                    class: "nav-link text-white" %>
              </li>

            <% elsif current_user.role == "student" %>

              <li class="nav-item">
                <%= link_to "Dashboard",
                    students_dashboard_path,
                    class: "nav-link text-white" %>
              </li>

            <% end %>

          <% else %>

            <li class="nav-item">
              <%= link_to "About Us",
                  "#about",
                  class: "nav-link text-white" %>
            </li>

            <li class="nav-item">
              <%= link_to "Admissions",
                  "#admissions",
                  class: "nav-link text-white" %>
            </li>

            <li class="nav-item">
              <%= link_to "Academics",
                  "#academics",
                  class: "nav-link text-white" %>
            </li>

            <li class="nav-item">
              <%= link_to "Departments",
                  "#departments",
                  class: "nav-link text-white" %>
            </li>

          <% end %>

        </ul>

        <!-- PROFILE / LOGIN -->
        <div class="dropdown ms-lg-3 mt-3 mt-lg-0">

          <% if user_signed_in? %>

            <% profile_name =
              case current_user.role
              when "student"
                current_user.student&.name
              when "teacher"
                current_user.teacher&.name
              when "department"
                current_user.department&.name
              else
                current_user.email
              end
            %>

            <button class="btn btn-outline-light dropdown-toggle d-flex flex-column align-items-center"
                    type="button"
                    data-bs-toggle="dropdown">

              <i class="fas fa-user-circle fs-4"></i>

              <small class="fw-bold">
                <%= profile_name %>
              </small>

              <span class="badge mt-1
                <%= case current_user.role
                    when "student" then "bg-danger"
                    when "teacher" then "bg-success"
                    when "department" then "bg-info text-dark"
                    when "admin" then "bg-warning text-dark"
                    else "bg-secondary"
                    end %>">

                <%= current_user.role.capitalize %>

              </span>

            </button>

            <ul class="dropdown-menu dropdown-menu-end">

              <li>
                <%= link_to "Home",
                    root_path,
                    class: "dropdown-item" %>
              </li>

              <li>
                <%= link_to "Help",
                    "#",
                    class: "dropdown-item" %>
              </li>

              <li>
                <hr class="dropdown-divider">
              </li>

              <li>
                <%= link_to "Logout",
                    destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "dropdown-item text-danger fw-bold" %>
              </li>

            </ul>

          <% else %>

            <%= link_to "Login",
                new_user_session_path,
                class: "btn btn-outline-light" %>

          <% end %>

        </div>

      </div>

    </div>

  </nav>
  

  <!-- FLASH MESSAGES -->
  <div class="container my-4">

    <% flash.each do |key, message| %>

      <div class="alert <%= key == 'notice' ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show">

        <%= message %>

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

      </div>

    <% end %>

  </div>

  <!-- PAGE CONTENT -->
  <main class="container mb-5 flex-grow-1">

    <%= yield %>

  </main>

  <!-- FOOTER -->
  <footer class="bg-dark text-light pt-5 pb-4 mt-auto">

    <div class="container">

      <div class="row">

        <!-- Quick Links -->
        <div class="col-md-4 mb-4">

          <h5 class="text-warning mb-3">
            Quick Links
          </h5>

          <p>
            <%= link_to "Home",
                root_path,
                class: "text-light text-decoration-none" %>
          </p>

          <p>
            <%= link_to "Departments",
                "#departments",
                class: "text-light text-decoration-none" %>
          </p>

        </div>

        <!-- Contact -->
        <div class="col-md-4 mb-4">

          <h5 class="text-warning mb-3">
            Contact Us
          </h5>

          <p>
            <i class="fas fa-home me-2"></i>
            Hyderabad, Telangana
          </p>

          <p>
            <i class="fas fa-envelope me-2"></i>
            info@rorec.edu.in
          </p>

          <p>
            <i class="fas fa-phone me-2"></i>
            +91 9876543210
          </p>

        </div>

        <!-- Logo -->
        <div class="col-md-4 text-center">

          <div class="rounded-circle bg-white d-inline-flex flex-column justify-content-center align-items-center mb-3"
               style="width: 100px; height: 100px;">

            <i class="bi bi-mortarboard-fill"
               style="font-size: 1.5rem; color: #ff4da6;"></i>

            <strong style="color: #ff4da6;">
              ROREC
            </strong>

          </div>

          <p class="text-light small">
            Ruby On Rails Engineering College
          </p>

        </div>

      </div>

      <hr class="border-secondary">

      <div class="text-center text-muted small">

        &copy; <%= Time.current.year %>
        ROREC - All Rights Reserved.

      </div>

    </div>

  </footer>

  <!-- Bootstrap Bundle JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>