<div class="mt-4 text-center link-container">

  <% if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "auth-link" %><br>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "auth-link" %><br>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "auth-link" %><br>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "auth-link" %><br>
  <% end %>

  <% if devise_mapping.omniauthable? %>
    <% resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "btn btn-outline-light mt-2" %><br>
    <% end %>
  <% end %>

</div>
<style>
  .link-container {
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
  }

  .auth-link {
    color: #ff4da6;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
    margin-bottom: 0.4rem;
  }

  .auth-link:hover {
    text-decoration: underline;
    color: #ffffff;
    text-shadow: 0 0 5px #ff4da6, 0 0 10px #ff4da6;
  }

  .btn-outline-light {
    border: 1px solid #ff4da6;
    color: #ff4da6;
    border-radius: 50px;
    font-weight: 600;
    transition: 0.3s ease;
  }

  .btn-outline-light:hover {
    background: #ff4da6;
    color: white;
    box-shadow: 0 0 15px #ff4da6;
  }
</style>
