<div style="max-width: 600px; margin: 30px auto; background-color: #fff0f5; padding: 30px; border-radius: 12px; box-shadow: 0 0 10px rgba(0,0,0,0.05); font-family: Arial, sans-serif;">

  <!-- Logo and Title -->
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
    <span style="font-size: 2rem; color: #ff4da6;">🎓</span>
    <span style="color: #ff4da6; font-size: 2.5rem; font-weight: bold; letter-spacing: 1px;">ROREC</span>
  </div>

  <!-- Welcome Heading -->
  <h1 style="color: #4a90e2; font-size: 28px; margin-bottom: 10px;">
    Welcome, <%= @user.email %>!
  </h1>

  <!-- Message Content -->
  <p style="font-size: 16px; color: #333; line-height: 1.6;">
    Your account has been successfully created. 🎉<br />
    You can now log in and access your personalized dashboard based on your role.
  </p>

  <!-- Login Button -->
  <div style="margin-top: 25px;">
    <a href="<%= root_url %>"
       style="display: inline-block; background-color: #4a90e2; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold;">
      🔐 Go to Dashboard
    </a>
  </div>
</div>
