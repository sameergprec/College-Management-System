<div class="container py-3">

  <!-- ACTIONS -->
  <div class="d-flex justify-content-between align-items-center mb-3">

    <%= link_to "← Back",
        results_path,
        class: "btn btn-sm btn-outline-secondary" %>

    <div>

      <button onclick="window.print()"
              class="btn btn-sm btn-success">
        Print
      </button>

      <button onclick="window.print()"
              class="btn btn-sm btn-danger">
        Download PDF
      </button>

    </div>

  </div>

  <!-- TITLE -->
  <div class="text-center mb-3">

    <h4 class="fw-bold mb-1">
      Examination Results
    </h4>

    <small class="text-muted">
      Student Academic Report
    </small>

  </div>

  <!-- STUDENT DETAILS -->
  <div class="card shadow-sm mb-3">

    <div class="card-header py-2 fw-semibold">
      Student Information
    </div>

    <div class="card-body p-0">

      <table class="table table-bordered table-sm mb-0">

        <tbody>

          <tr>
            <th width="20%">Roll Number</th>
            <td><%= @student.roll_no %></td>

            <th width="20%">Name</th>
            <td><%= @student.name %></td>
          </tr>

          <tr>
            <th>Course</th>
            <td><%= @student.course %></td>

            <th>Semester</th>
            <td><%= @student.semester %></td>
          </tr>

          <tr>
            <th>Section</th>
            <td><%= @student.section %></td>

            <th>Scheme</th>
            <td><%= @student.scheme %></td>
          </tr>

        </tbody>

      </table>

    </div>

  </div>

  <!-- MARKS TABLE -->
  <div class="card shadow-sm mb-3">

    <div class="card-header py-2 fw-semibold">
      Subject Wise Results
    </div>

    <div class="card-body p-0">

      <div class="table-responsive">

        <table class="table table-bordered table-striped table-sm mb-0">

          <thead class="table-light">

            <tr>
              <th>Subject Code</th>
              <th>Subject Name</th>
              <th>Sessional</th>
              <th>External</th>
              <th class="text-center">Total</th>
              <th class="text-center">Grade</th>
              <th class="text-center">GPA</th>
              <th class="text-center">Result</th>
            </tr>

          </thead>

          <tbody>

            <% @marks.each do |mark| %>

              <tr>

                <td>
                  <%= mark.subject_code %>
                </td>

                <td>
                  <%= mark.subject_name %>
                </td>

               <td>
                    <% internal = mark.final_internal.to_f %>
                    <%= (internal % 1) >= 0.75 ? internal.ceil : internal.floor %>
                </td>

                <td>
                  <%= mark.external_exam %>
                </td>

                <td class="text-center fw-bold">
                    <% total = mark.final_total.to_f %>
                    <%= (total % 1) >= 0.75 ? total.ceil : total.floor %>
                </td>

                <td class="text-center">
                  <%= mark.grade %>
                </td>

                <td class="text-center fw-bold">
                  <%= mark.gpa %>
                </td>

                <td class="text-center">

                  <% if mark.result == "PASS" %>

                    <span class="badge bg-success">
                      P
                    </span>

                  <% else %>

                    <span class="badge bg-danger">
                      F
                    </span>

                  <% end %>

                </td>

              </tr>

            <% end %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

  <!-- SUMMARY -->
  <div class="card shadow-sm">

    <div class="card-header py-2 fw-semibold">
      Result Summary
    </div>

    <div class="card-body p-0">

      <table class="table table-bordered table-sm mb-0">

        <tbody>

          <tr>
            <th>Total Subjects</th>
            <td><%= @summary[:total_subjects] %></td>

            <th>Passed</th>
            <td class="text-success fw-semibold">
              <%= @summary[:passed_subjects] %>
            </td>
          </tr>

          <tr>
            <th>Failed</th>
            <td class="text-danger fw-semibold">
              <%= @summary[:failed_subjects] %>
            </td>

            <th>Overall GPA</th>
            <td>
              <%= @summary[:average_gpa] %>
            </td>
          </tr>

          <tr>
            <th>Final Result</th>

            <td colspan="3">

              <% if @summary[:result] == "PASS" %>

                <span class="badge bg-success">
                  PASS
                </span>

              <% else %>

                <span class="badge bg-danger">
                  FAIL
                </span>

              <% end %>

            </td>

          </tr>

        </tbody>

      </table>

    </div>

  </div>

</div>

<style>
.table th,
.table td {
  vertical-align: middle;
  font-size: 14px;
}

.card-header {
  background: #f8f9fa;
}

@media print {
  .btn {
    display: none !important;
  }
}
</style>